direction: right

child_sheet: {
  label: "1. Child sheet"
  style.fill: "#ffffff"
  style.stroke: "#1b1b1b"
  style.shadow: true

  component_x: {
    label: "component x"
    style.fill: "#dbeafe"
    style.stroke: "#dbeafe"
  }

  component_y: {
    label: "component y"
    style.fill: "#fde68a"
    style.stroke: "#fde68a"
  }

  read_port: {
    label: "r"
    shape: circle
    width: 28
    height: 28
    style.fill: "#dbeafe"
    style.stroke: "#dbeafe"
  }

  process_port: {
    label: "p"
    shape: circle
    width: 28
    height: 28
    style.fill: "#fde68a"
    style.stroke: "#fde68a"
  }

  write_port: {
    label: "w"
    shape: circle
    width: 28
    height: 28
    style.fill: "#fecaca"
    style.stroke: "#fecaca"
  }
}

main_sheet: {
  label: "2. Main sheet"
  style.fill: "#ffffff"
  style.stroke: "#1b1b1b"
  style.shadow: true

  read_in: {
    label: "r"
    shape: circle
    width: 28
    height: 28
    style.fill: "#dbeafe"
    style.stroke: "#dbeafe"
  }

  process_in: {
    label: "p"
    shape: circle
    width: 28
    height: 28
    style.fill: "#fde68a"
    style.stroke: "#fde68a"
  }

  write_in: {
    label: "w"
    shape: circle
    width: 28
    height: 28
    style.fill: "#fecaca"
    style.stroke: "#fecaca"
  }

  main_out: {
    label: "main"
    shape: circle
    width: 34
    height: 34
    style.fill: "#dcfce7"
    style.stroke: "#dcfce7"
  }
}

generated_hal: {
  label: "3. Generated HAL"
  style.fill: "#fffaf1"
  style.stroke: "#1b1b1b"
  style.shadow: true

  code: {
    label: "addf x.read servo-thread\naddf y.process servo-thread\naddf x.write servo-thread"
    style.fill: "#fffaf1"
    style.stroke: "#fffaf1"
    style.font: mono
  }
}

child_sheet.component_x -> child_sheet.read_port
child_sheet.component_y -> child_sheet.process_port
child_sheet.component_x -> child_sheet.write_port

child_sheet.read_port -> main_sheet.read_in
child_sheet.process_port -> main_sheet.process_in
child_sheet.write_port -> main_sheet.write_in

main_sheet.read_in -> main_sheet.main_out
main_sheet.process_in -> main_sheet.main_out
main_sheet.write_in -> main_sheet.main_out

main_sheet.main_out -> generated_hal.code: "servo-thread"
