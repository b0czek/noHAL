{
  "name": "@nohal/core",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./addfQueue": "./src/addfQueue.ts",
    "./compParser": "./src/compParser.ts",
    "./componentFunctions": "./src/componentFunctions.ts",
    "./componentInstance": "./src/componentInstance.ts",
    "./componentNaming": "./src/componentNaming.ts",
    "./componentStore": "./src/componentStore/index.ts",
    "./customComponentStore": "./src/customComponentStore/index.ts",
    "./componentSystem": "./src/componentSystem.ts",
    "./componentVisibility": "./src/componentVisibility.ts",
    "./customComponent": "./src/customComponent/index.ts",
    "./graph": "./src/graph.ts",
    "./halImport": "./src/halImport/index.ts",
    "./halNames": "./src/halNames.ts",
    "./halThread": "./src/halThread/index.ts",
    "./halui": "./src/halui/index.ts",
    "./id": "./src/id.ts",
    "./ini": "./src/ini/index.ts",
    "./iocontrol": "./src/iocontrol/index.ts",
    "./linuxcncVersion": "./src/linuxcncVersion.ts",
    "./machineConfig": "./src/machineConfig/index.ts",
    "./machineConfigImport": "./src/machineConfigImport.ts",
    "./mesa": "./src/mesa/index.ts",
    "./motmod": "./src/motmod/index.ts",
    "./project": "./src/project/index.ts",
    "./sheet": "./src/sheet/index.ts",
    "./types": "./src/types/index.ts",
    "./validation": "./src/validation.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "generate:linuxcnc-stores": "node --loader ts-node/esm scripts/generate-linuxcnc-stores.ts && pnpm exec biome check --write src/componentStore/catalog/generated",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "remeda": "^2.33.6"
  }
}
