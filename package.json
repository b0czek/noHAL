{
  "name": "nohal-workspace",
  "private": true,
  "version": "0.3.0",
  "description": "NoHAL monorepo",
  "scripts": {
    "dev": "pnpm --filter @nohal/desktop dev",
    "build": "pnpm --filter @nohal/desktop build",
    "pack": "pnpm --filter @nohal/desktop pack",
    "dist": "pnpm --filter @nohal/desktop dist",
    "dist:linux": "pnpm --filter @nohal/desktop dist:linux",
    "dist:win": "pnpm --filter @nohal/desktop dist:win",
    "preview": "pnpm --filter @nohal/desktop preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:diagrams": "bash docs/scripts/render-diagrams.sh",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @nohal/desktop test:watch",
    "generate:linuxcnc-stores": "pnpm --filter @nohal/core generate:linuxcnc-stores",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "vitepress": "^1.6.4"
  }
}
