{
  "name": "nohal-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "NoHAL monorepo",
  "scripts": {
    "dev": "pnpm --filter @nohal/desktop dev",
    "build": "pnpm --filter @nohal/desktop build",
    "preview": "pnpm --filter @nohal/desktop preview",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @nohal/desktop test:watch",
    "generate:linuxcnc-stores": "pnpm --filter @nohal/core generate:linuxcnc-stores",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4"
  }
}
